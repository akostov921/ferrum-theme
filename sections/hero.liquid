{%- comment %} Composition: hero.centered-manifesto.headline-only — single centered headline, type-led, no image {% endcomment -%}
<section class="fe-hero" data-section-id="{{ section.id }}">
  <div class="fe-page fe-hero__core fe-reveal">
    <span class="fe-eyebrow">{{ section.settings.eyebrow }}</span>
    <h1 class="fe-display fe-hero__heading">{{ section.settings.heading }}</h1>
    <p class="fe-lead">{{ section.settings.lead }}</p>
    {%- if section.settings.cta_text != blank -%}<a class="fe-btn fe-btn--accent fe-hero__cta" href="{{ section.settings.cta_link }}">{{ section.settings.cta_text }}</a>{%- endif -%}
  </div>
  <div class="fe-hero__band">
    <div class="fe-page fe-hero__band-inner">
      <div><span class="fe-eyebrow">01</span><strong>Modular</strong></div>
      <div><span class="fe-eyebrow">02</span><strong>Repairable</strong></div>
      <div><span class="fe-eyebrow">03</span><strong>Recycled fibers</strong></div>
      <div><span class="fe-eyebrow">04</span><strong>Lifetime warranty</strong></div>
    </div>
  </div>
</section>
{% stylesheet %}
.fe-hero { padding-top: clamp(4rem, 12vw, 9rem); padding-bottom: 0; }
.fe-hero__core { min-height: 50vh; display: grid; place-items: center; text-align: center; gap: var(--fe-space-4); justify-items: center; max-width: 32ch; }
.fe-hero__heading { max-width: 18ch; }
.fe-hero__core .fe-lead { max-width: 40ch; text-align: center; }
.fe-hero__cta { margin-top: var(--fe-space-3); }
.fe-hero__band { background: var(--fe-ink); color: var(--fe-paper); margin-top: clamp(4rem, 8vw, 7rem); padding-block: var(--fe-space-5); }
.fe-hero__band-inner { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--fe-space-5); }
.fe-hero__band-inner > div { display: grid; gap: var(--fe-space-1); }
.fe-hero__band-inner .fe-eyebrow { color: var(--fe-accent); }
.fe-hero__band-inner strong { font-family: var(--fe-display); font-weight: 600; font-size: 1.0625rem; }
@media (max-width: 720px) { .fe-hero__band-inner { grid-template-columns: repeat(2, 1fr); gap: var(--fe-space-4); } }
{% endstylesheet %}
{% schema %}
{ "name": "Hero (manifesto)", "tag": "section", "settings": [
  { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FERRUM · FW26" },
  { "type": "text", "id": "heading", "label": "Heading", "default": "Outerwear, built to layer." },
  { "type": "textarea", "id": "lead", "label": "Lead", "default": "Modular shells, liners, and base layers — each engineered to work alone or together. Buy what you need; clip in the rest as the season turns." },
  { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Shop the system →" },
  { "type": "url", "id": "cta_link", "label": "CTA link" }
], "presets": [{ "name": "Hero (manifesto)" }] }
{% endschema %}
