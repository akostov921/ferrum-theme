<section class="fe-img-text fe-section">
  <div class="fe-page fe-img-text__grid">
    {%- assign img_first = section.settings.image_position | default: 'right' -%}
    <div class="fe-img-text__media{% if img_first == 'left' %} order-first{% endif %}">
      {%- if section.settings.image != blank -%}{%- assign ialt = section.settings.heading | escape -%}{{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '500,800,1200', sizes: '(min-width:880px) 50vw, 100vw', alt: ialt, class: 'fe-img-text__img' }}
      {%- elsif section.settings.fallback_url != blank -%}<img src="{{ section.settings.fallback_url }}" alt="" class="fe-img-text__img" width="1200" height="900" loading="lazy">{%- endif -%}
    </div>
    <div class="fe-img-text__copy">
      {%- if section.settings.eyebrow != blank -%}<span class="fe-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2 class="fe-h2">{{ section.settings.heading }}</h2>
      <div class="fe-img-text__body">{{ section.settings.body }}</div>
      {%- if section.settings.cta_text != blank -%}<a class="fe-btn" href="{{ section.settings.cta_link }}">{{ section.settings.cta_text }}</a>{%- endif -%}
    </div>
  </div>
</section>
{% stylesheet %}
.fe-img-text__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
.fe-img-text__copy { display: grid; gap: 1rem; max-width: 50ch; }
.fe-img-text__img { width: 100%; aspect-ratio: 4/3; object-fit: cover; border-radius: 8px; }
.order-first { order: -1; }
@media (max-width: 880px) { .fe-img-text__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}
{% schema %}
{ "name": "Image with text", "tag": "section", "settings": [
  { "type": "select", "id": "image_position", "label": "Image position", "options": [{ "value": "left", "label": "Left" }, { "value": "right", "label": "Right" }], "default": "right" },
  { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why we make this" },
  { "type": "text", "id": "heading", "label": "Heading", "default": "Made the slow way." },
  { "type": "richtext", "id": "body", "label": "Body", "default": "<p>A single paragraph that earns its space here — under 60 words ideally.</p>" },
  { "type": "image_picker", "id": "image", "label": "Image" },
  { "type": "text", "id": "fallback_url", "label": "Fallback image URL (Unsplash)" },
  { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Read more" },
  { "type": "url", "id": "cta_link", "label": "CTA link" }
], "presets": [{ "name": "Image with text" }]}
{% endschema %}
