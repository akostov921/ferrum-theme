<section class="fe-sus fe-section">
  <div class="fe-page fe-sus__grid">
    <div class="fe-sus__copy">
      <span class="fe-eyebrow">{{ section.settings.eyebrow | default: 'COMMITMENTS' }}</span>
      <h2 class="fe-h2">{{ section.settings.heading }}</h2>
      <p class="fe-lead">{{ section.settings.body }}</p>
      {%- if section.settings.cta_text != blank -%}<a class="fe-link" href="{{ section.settings.cta_link }}">{{ section.settings.cta_text }}</a>{%- endif -%}
    </div>
    <div class="fe-sus__stats">
      {%- for block in section.blocks -%}
        <div class="fe-sus__stat" {{ block.shopify_attributes }}>
          <strong class="fe-sus__number">{{ block.settings.number }}</strong>
          <span class="fe-sus__label">{{ block.settings.label }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{% stylesheet %}
.fe-sus__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
.fe-sus__copy { display: grid; gap: 1rem; max-width: 50ch; }
.fe-sus__stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
.fe-sus__stat { padding: 1.5rem; border: 1px solid rgba(0,0,0,0.1); border-radius: 8px; display: grid; gap: 0.5rem; }
.fe-sus__number { font-family: var(--fe-display); font-size: clamp(2rem, 3vw, 2.75rem); line-height: 1; font-weight: 600; }
.fe-sus__label { font-size: 0.875rem; opacity: 0.7; line-height: 1.4; }
@media (max-width: 880px) { .fe-sus__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}
{% schema %}
{ "name": "Sustainability panel", "tag": "section", "settings": [
  { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "COMMITMENTS" },
  { "type": "text", "id": "heading", "label": "Heading", "default": "What we measure." },
  { "type": "textarea", "id": "body", "label": "Body", "default": "Numbers, not claims. We publish an annual transparency report; here are the highlights." },
  { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Read the full report" },
  { "type": "url", "id": "cta_link", "label": "CTA link" }
], "blocks": [
  { "type": "stat", "name": "Stat", "settings": [
    { "type": "text", "id": "number", "label": "Number", "default": "92%" },
    { "type": "text", "id": "label", "label": "Label", "default": "Of our packaging is post-consumer recycled" }
  ]}
], "max_blocks": 6, "presets": [{ "name": "Sustainability panel", "blocks": [
  { "type": "stat", "settings": { "number": "92%", "label": "Of our packaging is post-consumer recycled" } },
  { "type": "stat", "settings": { "number": "0", "label": "Animals tested on, ever" } },
  { "type": "stat", "settings": { "number": "1%", "label": "Of revenue donated to community partners" } },
  { "type": "stat", "settings": { "number": "30 days", "label": "No-questions return window" } }
]}]}
{% endschema %}
