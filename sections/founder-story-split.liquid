<section class="fe-founder fe-section">
  <div class="fe-page fe-founder__grid">
    <div class="fe-founder__copy">
      <span class="fe-eyebrow">{{ section.settings.eyebrow | default: 'OUR STORY' }}</span>
      <h2 class="fe-h2">{{ section.settings.heading }}</h2>
      <div class="fe-founder__body">{{ section.settings.copy }}</div>
      <div class="fe-founder__sig">
        {%- if section.settings.sig_name != blank -%}<span class="fe-founder__sig-name">{{ section.settings.sig_name }}</span>{%- endif -%}
        {%- if section.settings.sig_role != blank -%}<small>{{ section.settings.sig_role }}</small>{%- endif -%}
      </div>
      {%- if section.settings.cta_text != blank -%}<a class="fe-link" href="{{ section.settings.cta_link }}">{{ section.settings.cta_text }}</a>{%- endif -%}
    </div>
    <div class="fe-founder__media">
      {%- if section.settings.image != blank -%}{%- assign falt = section.settings.sig_name | default: section.settings.heading | escape -%}{{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: falt, class: 'fe-founder__img' }}
      {%- elsif section.settings.fallback_url != blank -%}<img src="{{ section.settings.fallback_url }}" class="fe-founder__img" alt="" width="1000" height="1300" loading="lazy">{%- endif -%}
    </div>
  </div>
</section>
{% stylesheet %}
.fe-founder__grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 4rem; align-items: center; }
.fe-founder__copy { display: grid; gap: 1rem; max-width: 56ch; }
.fe-founder__body { font-size: 1.0625rem; line-height: 1.65; opacity: 0.8; }
.fe-founder__body p { margin-bottom: 1rem; }
.fe-founder__sig { display: grid; gap: 0.25rem; margin-top: 0.5rem; }
.fe-founder__sig-name { font-size: 1.25rem; font-style: italic; }
.fe-founder__img { width: 100%; aspect-ratio: 4/5; object-fit: cover; border-radius: 8px; }
@media (max-width: 880px) { .fe-founder__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}
{% schema %}
{ "name": "Founder story", "tag": "section", "settings": [
  { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "OUR STORY" },
  { "type": "text", "id": "heading", "label": "Heading", "default": "Started in a kitchen." },
  { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>We started this brand after years of looking for something we couldn't find. So we made it.</p>" },
  { "type": "text", "id": "sig_name", "label": "Signature name", "default": "Anna Mendez" },
  { "type": "text", "id": "sig_role", "label": "Signature role", "default": "Founder" },
  { "type": "image_picker", "id": "image", "label": "Founder photo" },
  { "type": "text", "id": "fallback_url", "label": "Fallback image URL" },
  { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Read the full story" },
  { "type": "url", "id": "cta_link", "label": "CTA link" }
], "presets": [{ "name": "Founder story" }]}
{% endschema %}
