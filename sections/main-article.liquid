<article class="fe-article fe-section">
  <div class="fe-page fe-page--narrow">
    <header class="fe-article__head">
      <small class="fe-eyebrow">{{ article.published_at | date: '%B %-d, %Y' }} · {{ blog.title }}</small>
      <h1 class="fe-display fe-article__title">{{ article.title }}</h1>
      {%- if article.user.first_name -%}
        <p class="fe-italic">By {{ article.user.first_name }} {{ article.user.last_name }}</p>
      {%- endif -%}
    </header>
    {%- if article.image -%}
      <figure class="fe-article__hero">
        {{ article.image | image_url: width: 1400 | image_tag: loading: 'eager', widths: '720,1100,1400,1800', alt: article.title | escape }}
      </figure>
    {%- endif -%}
    <div class="fe-article__body">{{ article.content }}</div>
  </div>
</article>

{% stylesheet %}
.fe-article__head { display: grid; gap: var(--fe-space-3); margin-bottom: var(--fe-space-7); }
.fe-article__title { margin-top: var(--fe-space-2); }
.fe-article__hero { margin: var(--fe-space-6) 0; }
.fe-article__hero img { width: 100%; }
.fe-article__body { font-size: 1.0625rem; line-height: 1.75; color: var(--fe-ink-soft); }
.fe-article__body p { margin-bottom: var(--fe-space-4); }
.fe-article__body p:first-of-type::first-letter { font-family: var(--fe-serif); font-size: 4em; line-height: 0.85; float: left; padding-right: 0.15em; padding-top: 0.05em; }
.fe-article__body h2, .fe-article__body h3 { font-family: var(--fe-serif); color: var(--fe-ink); margin-top: var(--fe-space-6); margin-bottom: var(--fe-space-3); }
.fe-article__body a { color: var(--fe-accent); border-bottom: 1px solid currentColor; }
.fe-article__body blockquote { font-family: var(--fe-serif); font-style: italic; font-size: 1.5rem; line-height: 1.35; border-left: 1px solid var(--fe-ink); padding-left: var(--fe-space-5); margin-block: var(--fe-space-5); color: var(--fe-ink); }
{% endstylesheet %}

{% schema %}{ "name": "Article", "tag": "article" }{% endschema %}
