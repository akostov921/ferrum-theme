{%- comment %} Composition: collection.tag-grouped — multiple horizontal rails by tag (system layers) {% endcomment -%}
<section class="fe-feat fe-section" data-section-id="{{ section.id }}">
  <div class="fe-page">
    <header class="fe-feat__head fe-reveal">
      <div>
        <span class="fe-eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="fe-h1">{{ section.settings.heading }}</h2>
      </div>
    </header>
    {%- for block in section.blocks -%}
      {%- assign group = collections[block.settings.collection] -%}
      <div class="fe-feat__rail fe-reveal">
        <header class="fe-feat__rail-head">
          <h3 class="fe-h3">{{ block.settings.heading | default: group.title }}</h3>
          {%- if group != blank and group.url -%}<a class="fe-eyebrow" href="{{ group.url }}">See all →</a>{%- endif -%}
        </header>
        <div class="fe-feat__rail-track">
          {%- if group.products.size > 0 -%}
            {%- for product in group.products limit: 8 -%}{% render 'product-card', product: product %}{%- endfor -%}
          {%- else -%}
            {%- for i in (1..5) -%}
              <a class="fe-card" href="#">
                <div class="fe-card__media fe-card__media--cover"><img src="https://images.unsplash.com/photo-{{ '1551488831-00ddcb6c6bd3,1591047139829-d91aecb6caea,1542272604-787c3835535d,1551028719-00167b16eac5,1556909114-f6e7ad7d3136' | split: ',' | slice: forloop.index0 | first }}?w=800&q=85" alt="" width="800" height="1000" loading="lazy" class="fe-card__img"></div>
                <div class="fe-card__body"><h3 class="fe-card__title">Sample piece {{ i }}</h3><span class="fe-card__price">${{ 89 | times: forloop.index | divided_by: 2 | plus: 60 }}</span></div>
              </a>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>
{% stylesheet %}
.fe-feat__head { margin-bottom: var(--fe-space-6); }
.fe-feat__head .fe-h1 { margin-top: var(--fe-space-2); }
.fe-feat__rail { margin-block: var(--fe-space-6); }
.fe-feat__rail-head { display: flex; justify-content: space-between; align-items: end; padding-bottom: var(--fe-space-3); margin-bottom: var(--fe-space-4); border-bottom: 1px solid var(--fe-line); }
.fe-feat__rail-track { display: grid; grid-auto-flow: column; grid-auto-columns: minmax(220px, 1fr); gap: var(--fe-space-4); overflow-x: auto; overscroll-behavior-x: contain; scroll-snap-type: x mandatory; padding-bottom: var(--fe-space-3); }
.fe-feat__rail-track > * { scroll-snap-align: start; }
{% endstylesheet %}
{% schema %}
{ "name": "Featured (tag rails)", "tag": "section", "settings": [
  { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "THE SYSTEM" },
  { "type": "text", "id": "heading", "label": "Heading", "default": "Layer for any weather." }
], "blocks": [
  { "type": "rail", "name": "Tag rail", "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shells" },
    { "type": "collection", "id": "collection", "label": "Collection" }
  ]}
], "max_blocks": 6, "presets": [{ "name": "Featured (tag rails)", "blocks": [
  { "type": "rail", "settings": { "heading": "Shells" } }, { "type": "rail", "settings": { "heading": "Liners" } }, { "type": "rail", "settings": { "heading": "Base layers" } }
] }] }
{% endschema %}
