<section class="fe-cart fe-section" data-section-id="{{ section.id }}">
  <div class="fe-page fe-page--narrow">
    <header><span class="fe-eyebrow">Basket</span><h1 class="fe-h1">Your basket</h1></header>
    <div class="fe-rule"></div>
    {%- if cart.item_count > 0 -%}
      {%- form 'cart', cart -%}
        <ul class="fe-cart__items">
          {%- for item in cart.items -%}
            <li class="fe-cart__row" data-key="{{ item.key }}">
              <a href="{{ item.url }}" class="fe-cart__media">
                {%- if item.image -%}{{ item.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: item.title | escape }}{%- else -%}<span>—</span>{%- endif -%}
              </a>
              <div class="fe-cart__meta">
                <a href="{{ item.url }}" class="fe-h3">{{ item.product.title }}</a>
                {%- if item.product.vendor != blank -%}<small class="fe-italic">{{ item.product.vendor }}</small>{%- endif -%}
                {%- if item.variant.title != 'Default Title' -%}<small>{{ item.variant.title }}</small>{%- endif -%}
              </div>
              <div class="fe-cart__qty">
                <input type="number" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" aria-label="Quantity">
                <a href="{{ routes.cart_change_url }}?id={{ item.key }}&quantity=0" class="fe-cart__remove">Remove</a>
              </div>
              <div class="fe-cart__price">{{ item.final_line_price | money_without_trailing_zeros }}</div>
            </li>
          {%- endfor -%}
        </ul>
        <footer class="fe-cart__foot">
          <div class="fe-cart__subtotal">
            <span class="fe-eyebrow">Subtotal</span>
            <strong class="fe-h2">{{ cart.total_price | money_with_currency }}</strong>
            <small>Tax and shipping calculated at checkout.</small>
          </div>
          <div class="fe-cart__actions">
            <button type="submit" name="update" class="fe-btn fe-btn--ghost">Update</button>
            <button type="submit" name="checkout" class="fe-btn">Checkout</button>
          </div>
        </footer>
      {%- endform -%}
    {%- else -%}
      <div class="fe-cart__empty">
        <p class="fe-display">An empty page.</p>
        <p class="fe-lead">It has its own beauty, but you probably wanted books.</p>
        <a class="fe-link" href="{{ routes.all_products_collection_url }}">Read the catalogue</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.fe-cart__items { list-style: none; padding: 0; margin: 0; }
.fe-cart__row {
  display: grid; grid-template-columns: 80px 1fr auto auto;
  gap: var(--fe-space-4);
  padding-block: var(--fe-space-4);
  border-bottom: 1px solid var(--fe-rule);
  align-items: center;
}
.fe-cart__media img { width: 100%; aspect-ratio: 3/4; object-fit: cover; background: var(--fe-paper-2); }
.fe-cart__media span { display: grid; place-items: center; aspect-ratio: 3/4; background: var(--fe-paper-2); font-family: var(--fe-serif); }
.fe-cart__meta { display: grid; gap: var(--fe-space-1); }
.fe-cart__meta a { color: inherit; }
.fe-cart__meta small { color: var(--fe-ink-muted); font-size: var(--fe-fs-sm); }
.fe-cart__qty input { width: 60px; padding: 0.3rem; border: 1px solid var(--fe-rule); font: inherit; text-align: center; }
.fe-cart__qty { display: grid; gap: var(--fe-space-1); justify-items: end; }
.fe-cart__remove { color: var(--fe-ink-muted); font-size: var(--fe-fs-xs); text-decoration: underline; }
.fe-cart__price { font-family: var(--fe-serif); font-size: 1.125rem; }
.fe-cart__foot { display: flex; justify-content: space-between; align-items: end; flex-wrap: wrap; gap: var(--fe-space-4); margin-top: var(--fe-space-5); }
.fe-cart__subtotal { display: grid; gap: var(--fe-space-1); }
.fe-cart__subtotal small { color: var(--fe-ink-muted); font-size: var(--fe-fs-sm); }
.fe-cart__actions { display: flex; gap: var(--fe-space-3); }
.fe-cart__empty { text-align: center; padding-block: var(--fe-space-9); display: grid; gap: var(--fe-space-4); justify-items: center; }
@media (max-width: 640px) { .fe-cart__row { grid-template-columns: 60px 1fr; row-gap: var(--fe-space-2); } .fe-cart__qty, .fe-cart__price { grid-column: 2; } }
{% endstylesheet %}

{% schema %}{ "name": "Cart", "tag": "section" }{% endschema %}
