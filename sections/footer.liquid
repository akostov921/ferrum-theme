<footer class="fe-footer" data-section-id="{{ section.id }}">
  <div class="fe-page fe-footer__top">
    <div class="fe-footer__brand">
      <p class="fe-h2 fe-footer__wm">{{ shop.name }}<span class="fe-footer__dot">●</span></p>
      {%- if section.settings.tagline != blank -%}<p class="fe-footer__tagline">{{ section.settings.tagline }}</p>{%- endif -%}
    </div>
    <div class="fe-footer__cols">
      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}<div class="fe-footer__col" {{ block.shopify_attributes }}><h4 class="fe-eyebrow">{{ block.settings.heading }}</h4><ul>{%- for link in linklists[block.settings.menu].links -%}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{%- endfor -%}</ul></div>
        {%- elsif block.type == 'text' -%}<div class="fe-footer__col" {{ block.shopify_attributes }}><h4 class="fe-eyebrow">{{ block.settings.heading }}</h4><div>{{ block.settings.text }}</div></div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
  <div class="fe-rule"></div>
  <div class="fe-page fe-footer__bottom"><small>© {{ 'now' | date: '%Y' }} {{ shop.name }} · Modular outerwear since 2022</small></div>
</footer>
{% stylesheet %}
.fe-footer { background: var(--fe-bg-2); padding-block: var(--fe-space-7) var(--fe-space-4); margin-top: var(--fe-space-8); }
.fe-footer__top { display: grid; grid-template-columns: 1fr 2fr; gap: var(--fe-space-7); padding-bottom: var(--fe-space-6); }
.fe-footer__wm { letter-spacing: -0.02em; }
.fe-footer__dot { color: var(--fe-accent-deep); margin-left: 4px; }
.fe-footer__tagline { color: var(--fe-ink-soft); margin-top: var(--fe-space-2); font-size: var(--fe-fs-sm); max-width: 32ch; }
.fe-footer__cols { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: var(--fe-space-6); }
.fe-footer__col ul { list-style: none; padding: 0; margin-top: var(--fe-space-3); display: grid; gap: var(--fe-space-2); }
.fe-footer__col a { color: var(--fe-ink-soft); font-size: var(--fe-fs-sm); transition: color var(--fe-dur); }
.fe-footer__col a:hover { color: var(--fe-ink); }
.fe-footer__bottom { padding-top: var(--fe-space-5); color: var(--fe-mute); font-size: var(--fe-fs-sm); }
@media (max-width: 720px) { .fe-footer__top { grid-template-columns: 1fr; } }
{% endstylesheet %}
{% schema %}
{ "name": "Footer", "settings": [{ "type": "text", "id": "tagline", "label": "Tagline", "default": "Made to layer. Designed for repair. Built to outlast trends." }], "blocks": [
  { "type": "menu", "name": "Menu", "settings": [{ "type": "text", "id": "heading", "label": "Heading", "default": "Shop" }, { "type": "link_list", "id": "menu", "label": "Menu" }] },
  { "type": "text", "name": "Text", "settings": [{ "type": "text", "id": "heading", "label": "Heading", "default": "Support" }, { "type": "richtext", "id": "text", "label": "Text" }] }
], "max_blocks": 4 }
{% endschema %}
