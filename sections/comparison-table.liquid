<section class="fe-cmp fe-section">
  <div class="fe-page">
    <header class="fe-cmp__head">
      <span class="fe-eyebrow">{{ section.settings.eyebrow | default: 'WHY US' }}</span>
      <h2 class="fe-h2">{{ section.settings.heading }}</h2>
    </header>
    <table class="fe-cmp__table">
      <thead>
        <tr>
          <th></th>
          <th class="fe-cmp__us">{{ section.settings.brand_label | default: 'Us' }}</th>
          <th class="fe-cmp__them">{{ section.settings.others_label | default: 'Others' }}</th>
        </tr>
      </thead>
      <tbody>
        {%- for block in section.blocks -%}
          <tr {{ block.shopify_attributes }}>
            <th>{{ block.settings.criterion }}</th>
            <td class="fe-cmp__yes">{{ block.settings.us | default: '✓' }}</td>
            <td class="fe-cmp__no">{{ block.settings.them | default: '✗' }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
  </div>
</section>
{% stylesheet %}
.fe-cmp__head { display: grid; gap: 0.5rem; max-width: 56ch; margin-bottom: 2rem; }
.fe-cmp__table { width: 100%; border-collapse: collapse; max-width: 720px; margin: 0 auto; }
.fe-cmp__table th, .fe-cmp__table td { padding: 1rem; text-align: left; border-bottom: 1px solid rgba(0,0,0,0.1); font-size: 0.95rem; }
.fe-cmp__table thead th { text-transform: uppercase; letter-spacing: 0.04em; font-size: 0.75rem; opacity: 0.7; }
.fe-cmp__table tbody th { font-weight: 500; }
.fe-cmp__us { font-weight: 600; }
.fe-cmp__them { opacity: 0.6; }
.fe-cmp__yes { color: #2c8a4e; font-weight: 600; }
.fe-cmp__no { color: #c44a24; opacity: 0.7; }
{% endstylesheet %}
{% schema %}
{ "name": "Comparison table", "tag": "section", "settings": [
  { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "WHY US" },
  { "type": "text", "id": "heading", "label": "Heading", "default": "How we compare." },
  { "type": "text", "id": "brand_label", "label": "Brand column", "default": "Us" },
  { "type": "text", "id": "others_label", "label": "Others column", "default": "Others" }
], "blocks": [
  { "type": "row", "name": "Row", "settings": [
    { "type": "text", "id": "criterion", "label": "Criterion", "default": "Sulfate-free" },
    { "type": "text", "id": "us", "label": "Us value", "default": "✓" },
    { "type": "text", "id": "them", "label": "Them value", "default": "✗" }
  ]}
], "max_blocks": 12, "presets": [{ "name": "Comparison table", "blocks": [
  { "type": "row", "settings": { "criterion": "Sulfate-free" } },
  { "type": "row", "settings": { "criterion": "Cruelty-free" } },
  { "type": "row", "settings": { "criterion": "Free shipping > $50" } },
  { "type": "row", "settings": { "criterion": "30-day returns" } },
  { "type": "row", "settings": { "criterion": "Small-batch production", "them": "Mass production" } }
]}]}
{% endschema %}
