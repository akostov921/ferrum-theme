<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{ shop.name }} — coming soon</title>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,ital@9..144,500,0;9..144,500,1&family=Inter:wght@400;500&display=swap">
{{ 'base.css' | asset_url | stylesheet_tag }}{{ content_for_header }}</head>
<body><main class="fe-page fe-page--narrow fe-section" style="display: grid; place-items: center; min-height: 100vh; text-align: center;">
  <div style="display: grid; gap: 2rem;">
    <span class="fe-eyebrow">Coming soon</span>
    <h1 class="fe-display fe-italic">{{ shop.name }}</h1>
    <p class="fe-lead">{{ shop.password_message }}</p>
    {{ content_for_layout }}
  </div>
</main></body></html>
