<section class="fe-section"><div class="fe-page fe-page--narrow">
  <header><span class="fe-eyebrow">Account</span><h1 class="fe-display">Welcome, {{ customer.first_name | default: 'reader' }}.</h1></header>
  <div class="fe-rule"></div>
  <p style="margin-bottom: var(--fe-space-5);"><a class="fe-link" href="{{ routes.account_logout_url }}">Sign out</a></p>
  <h2 class="fe-h2">Orders</h2>
  {%- if customer.orders.size > 0 -%}
    <table class="fe-table">
      <thead><tr><th>Order</th><th>Date</th><th>Total</th><th>Status</th></tr></thead>
      <tbody>
        {%- for order in customer.orders -%}
          <tr><td><a class="fe-link" href="{{ order.customer_url }}">{{ order.name }}</a></td><td>{{ order.created_at | date: '%B %-d, %Y' }}</td><td>{{ order.total_price | money }}</td><td>{{ order.financial_status_label }}</td></tr>
        {%- endfor -%}
      </tbody>
    </table>
  {%- else -%}
    <p>No orders yet. <a class="fe-link" href="{{ routes.all_products_collection_url }}">Find your first book →</a></p>
  {%- endif -%}
  <h2 class="fe-h2" style="margin-top: var(--fe-space-7);">Addresses</h2>
  <p><a class="fe-link" href="{{ routes.account_addresses_url }}">Manage addresses</a></p>
</div></section>
<style>.fe-table { width: 100%; border-collapse: collapse; font-size: var(--fe-fs-sm); margin-top: var(--fe-space-3); } .fe-table th, .fe-table td { padding: var(--fe-space-3) var(--fe-space-2); text-align: left; border-bottom: 1px solid var(--fe-rule); } .fe-table th { color: var(--fe-ink-muted); font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; font-size: var(--fe-fs-xs); }</style>
