<section class="fe-section"><div class="fe-page fe-page--narrow">
  <header><span class="fe-eyebrow">Account</span><h1 class="fe-display">Create account</h1></header>
  <div class="fe-rule"></div>
  {%- form 'create_customer', class: 'fe-auth' -%}
    {{ form.errors | default_errors }}
    <label class="fe-eyebrow">First name <input class="fe-input" name="customer[first_name]" type="text"></label>
    <label class="fe-eyebrow">Last name <input class="fe-input" name="customer[last_name]" type="text"></label>
    <label class="fe-eyebrow">Email <input class="fe-input" name="customer[email]" type="email" required></label>
    <label class="fe-eyebrow">Password <input class="fe-input" name="customer[password]" type="password" required></label>
    <button type="submit" class="fe-btn">Create</button>
    <p class="fe-auth__alt"><a class="fe-link" href="{{ routes.account_login_url }}">Have an account? Sign in</a></p>
  {%- endform -%}
</div></section>
<style>.fe-auth { display: grid; gap: var(--fe-space-4); margin-top: var(--fe-space-4); } .fe-auth label { display: grid; gap: var(--fe-space-1); }</style>
