<section class="fe-section"><div class="fe-page fe-page--narrow">
  <h1 class="fe-display">Reset password</h1>
  {%- form 'reset_customer_password' -%}
    {{ form.errors | default_errors }}
    <label class="fe-eyebrow">New password <input class="fe-input" name="customer[password]" type="password" required></label>
    <label class="fe-eyebrow">Confirm <input class="fe-input" name="customer[password_confirmation]" type="password" required></label>
    <button type="submit" class="fe-btn">Reset</button>
  {%- endform -%}
</div></section>
